{
  "repo_url": "https://github.com/aram-devdocs/GoudEngine",
  "sections": [
    {
      "id": "baseline-parity",
      "title": "Baseline parity game: Flappy Bird",
      "description": "Flappy Bird is the behavior baseline across SDKs.",
      "entries": [
        {
          "name": "Flappy Goud",
          "sdk": "C#",
          "target": "Desktop",
          "path": "examples/csharp/flappy_goud",
          "run": "./dev.sh --game flappy_goud",
          "description": "Flappy Bird parity baseline.",
          "media": {
            "path": "docs/src/generated/showcase/flappy-goud-csharp-desktop.png",
            "alt": "Flappy Goud C# desktop preview"
          }
        },
        {
          "name": "Flappy Bird",
          "sdk": "Python",
          "target": "Desktop",
          "path": "examples/python/flappy_bird.py",
          "run": "./dev.sh --sdk python --game flappy_bird",
          "description": "Python parity baseline.",
          "media": {
            "path": "docs/src/generated/showcase/flappy-bird-python-desktop.png",
            "alt": "Flappy Bird Python desktop preview"
          }
        },
        {
          "name": "Flappy Bird",
          "sdk": "TypeScript",
          "target": "Desktop",
          "path": "examples/typescript/flappy_bird/desktop.ts",
          "run": "./dev.sh --sdk typescript --game flappy_bird",
          "description": "TypeScript desktop parity baseline.",
          "media": {
            "path": "docs/src/generated/showcase/flappy-bird-typescript-desktop.png",
            "alt": "Flappy Bird TypeScript desktop preview"
          }
        },
        {
          "name": "Flappy Bird",
          "sdk": "TypeScript",
          "target": "Web",
          "path": "examples/typescript/flappy_bird/web",
          "run": "./dev.sh --sdk typescript --game flappy_bird_web",
          "description": "TypeScript web parity baseline.",
          "media": {
            "path": "docs/src/generated/showcase/flappy-bird-typescript-web.png",
            "alt": "Flappy Bird TypeScript web preview"
          }
        },
        {
          "name": "Flappy Bird",
          "sdk": "Rust",
          "target": "Desktop",
          "path": "examples/rust/flappy_bird",
          "run": "cargo run -p flappy-bird",
          "description": "Native Rust parity baseline.",
          "media": {
            "path": "docs/src/generated/showcase/flappy-bird-rust-desktop.png",
            "alt": "Flappy Bird Rust desktop preview"
          }
        }
      ]
    },
