    {
      "id": "sandbox-parity",
      "title": "Sandbox parity target",
      "description": "Sandbox is the shared cross-language app for the broader Alpha-001 feature surface. This branch is still closing the remaining recovery rows, so treat the execution CSV as the live truth source.",
      "entries": [
        {
          "name": "Sandbox",
          "sdk": "C#",
          "target": "Desktop",
          "path": "examples/csharp/sandbox",
          "run": "./dev.sh --game sandbox",
          "description": "Manifest-driven desktop sandbox with the shared HUD and localhost peer contract. Current branch truth still tracks the remaining scene-flow recovery rows in the execution CSV.",
          "media": {
            "path": "docs/src/generated/showcase/sandbox-csharp-desktop.png",
            "alt": "Sandbox C# desktop preview"
          }
        },
        {
          "name": "Sandbox",
          "sdk": "Python",
          "target": "Desktop",
          "path": "examples/python/sandbox.py",
          "run": "./dev.sh --sdk python --game sandbox",
          "description": "Manifest-driven Python sandbox following the shared asset pack, three-panel HUD, and peer packet contract on this branch.",
          "media": {
            "path": "docs/src/generated/showcase/sandbox-python-desktop.png",
            "alt": "Sandbox Python desktop preview"
          }
        },
        {
          "name": "Sandbox",
          "sdk": "TypeScript",
          "target": "Desktop",
          "path": "examples/typescript/sandbox/desktop.ts",
          "run": "./dev.sh --sdk typescript --game sandbox",
          "description": "Manifest-driven TypeScript desktop sandbox following the shared HUD and peer packet contract on this branch.",
          "media": {
            "path": "docs/src/generated/showcase/sandbox-typescript-desktop.png",
            "alt": "Sandbox TypeScript desktop preview"
          }
        },
        {
          "name": "Sandbox",
          "sdk": "TypeScript",
          "target": "Web",
          "path": "examples/typescript/sandbox/web",
          "run": "./dev.sh --sdk typescript --game sandbox_web",
          "description": "Browser/WASM sandbox with the same HUD structure and explicit capability-gated networking and renderer copy.",
          "media": {
            "path": "docs/src/generated/showcase/sandbox-typescript-web.png",
            "alt": "Sandbox TypeScript web preview"
          }
        },
        {
          "name": "Sandbox",
          "sdk": "Rust",
          "target": "Desktop",
          "path": "examples/rust/sandbox",
          "run": "cargo run -p sandbox",
