pub(super) const VERTEX_SHADER_3D: &str = r#"
#version 330 core

layout (location = 0) in vec3 aPos;
layout (location = 1) in vec3 aNormal;
layout (location = 2) in vec2 aTexCoord;

out vec3 FragPos;
out vec3 Normal;
out vec2 TexCoord;
out vec4 FragPosLightSpace;

uniform mat4 model;
uniform mat4 view;
uniform mat4 projection;
uniform mat4 lightSpaceMatrix;

void main()
{
    FragPos = vec3(model * vec4(aPos, 1.0));
    Normal = mat3(transpose(inverse(model))) * aNormal;
    TexCoord = aTexCoord;
    FragPosLightSpace = lightSpaceMatrix * vec4(FragPos, 1.0);

    gl_Position = projection * view * vec4(FragPos, 1.0);
}
"#;

pub(super) const FRAGMENT_SHADER_3D: &str = r#"
#version 330 core

in vec3 FragPos;
in vec3 Normal;
in vec2 TexCoord;
in vec4 FragPosLightSpace;

out vec4 FragColor;

struct Light {
    int light_type;     // 0 = point, 1 = directional, 2 = spot
    vec3 position;
    vec3 direction;
    vec3 color;
    float intensity;
    float range;
    float spotAngle;
    bool enabled;
};

uniform sampler2D texture1;
uniform sampler2D shadowMap;
uniform vec3 viewPos;
uniform int numLights;
uniform Light lights[8];
uniform bool useTexture;
uniform vec4 objectColor;
uniform bool shadowsEnabled;
uniform float shadowBias;
uniform vec2 shadowTexelSize;

vec3 calculatePointLight(Light light, vec3 normal, vec3 fragPos, vec3 viewDir) {
    vec3 lightDir = normalize(light.position - fragPos);
    float distance = length(light.position - fragPos);
    float attenuation = 1.0 / (1.0 + 0.09 * distance + 0.032 * distance * distance);

    float diff = max(dot(normal, lightDir), 0.0);
    vec3 diffuse = diff * light.color;

    vec3 halfDir = normalize(lightDir + viewDir);
    float spec = pow(max(dot(normal, halfDir), 0.0), 64.0);
    vec3 specular = spec * light.color * 0.3;

    float rangeAttenuation = 1.0 - smoothstep(0.0, light.range, distance);

    return (diffuse + specular) * attenuation * rangeAttenuation * light.intensity;
}

vec3 calculateDirectionalLight(Light light, vec3 normal, vec3 viewDir) {
    vec3 lightDir = normalize(-light.direction);

    float diff = max(dot(normal, lightDir), 0.0);
    vec3 diffuse = diff * light.color;

    vec3 halfDir = normalize(lightDir + viewDir);
    float spec = pow(max(dot(normal, halfDir), 0.0), 64.0);
    vec3 specular = spec * light.color * 0.3;

    return (diffuse + specular) * light.intensity;
}

vec3 calculateSpotLight(Light light, vec3 normal, vec3 fragPos, vec3 viewDir) {
    vec3 lightDir = normalize(light.position - fragPos);
    float theta = dot(lightDir, normalize(-light.direction));
    float epsilon = cos(radians(light.spotAngle)) - cos(radians(light.spotAngle + 5.0));
    float intensity = clamp((theta - cos(radians(light.spotAngle + 5.0))) / epsilon, 0.0, 1.0);

    if (intensity > 0.0) {
        return calculatePointLight(light, normal, fragPos, viewDir) * intensity;
    }
    return vec3(0.0);
}

uniform bool fogEnabled;
uniform vec3 fogColor;
uniform float fogDensity;

float calculateFog(float distance) {
    float fog = exp(-pow(fogDensity * distance, 2.0));
    return clamp(fog, 0.0, 1.0);
}

float calculateShadowFactor() {
    if (!shadowsEnabled) {
        return 0.0;
    }

    vec3 projCoords = FragPosLightSpace.xyz / max(FragPosLightSpace.w, 0.0001);
    projCoords = projCoords * 0.5 + 0.5;
    if (projCoords.x < 0.0 || projCoords.x > 1.0 || projCoords.y < 0.0 || projCoords.y > 1.0 || projCoords.z > 1.0) {
        return 0.0;
    }

    float currentDepth = projCoords.z;
    float shadow = 0.0;
    vec2 texelSize = shadowTexelSize;
    for (int x = -1; x <= 1; x++) {
        for (int y = -1; y <= 1; y++) {
            float closestDepth = texture(shadowMap, projCoords.xy + vec2(x, y) * texelSize).r;
            shadow += currentDepth - shadowBias > closestDepth ? 1.0 : 0.0;
        }
    }
    return shadow / 9.0;
}

void main() {
    vec3 norm = normalize(Normal);
    vec3 viewDir = normalize(viewPos - FragPos);
    vec3 result = vec3(0.0);

    vec3 ambient = vec3(0.1);
    result += ambient;

    for(int i = 0; i < numLights && i < 8; i++) {
        if (!lights[i].enabled) continue;

        vec3 lightContribution;
        if (lights[i].light_type == 0) {
            lightContribution = calculatePointLight(lights[i], norm, FragPos, viewDir);
        }
        else if (lights[i].light_type == 1) {
            lightContribution = calculateDirectionalLight(lights[i], norm, viewDir);
        }
        else if (lights[i].light_type == 2) {
            lightContribution = calculateSpotLight(lights[i], norm, FragPos, viewDir);
        }

        result += lightContribution;
    }

    vec4 baseColor;
    if (useTexture) {
        baseColor = texture(texture1, TexCoord);
    } else {
        baseColor = objectColor;
    }

    float shadow = calculateShadowFactor();
    vec3 finalColor = (1.0 - 0.65 * shadow) * result * baseColor.rgb;

    if (fogEnabled) {
        float distance = length(FragPos - viewPos);
        float visibility = calculateFog(distance);
        finalColor = mix(fogColor, finalColor, visibility);
    }

    FragColor = vec4(finalColor, baseColor.a);
}
"#;

pub(super) const INSTANCED_VERTEX_SHADER_3D: &str = r#"
#version 330 core

layout (location = 0) in vec3 aPos;
layout (location = 1) in vec3 aNormal;
layout (location = 2) in vec2 aTexCoord;
layout (location = 3) in vec4 iModelCol0;
layout (location = 4) in vec4 iModelCol1;
layout (location = 5) in vec4 iModelCol2;
layout (location = 6) in vec4 iModelCol3;
layout (location = 7) in vec4 iColor;

out vec3 FragPos;
out vec3 Normal;
out vec2 TexCoord;
out vec4 InstanceColor;
out vec4 FragPosLightSpace;

uniform mat4 view;
uniform mat4 projection;
uniform mat4 lightSpaceMatrix;

void main()
{
    mat4 model = mat4(iModelCol0, iModelCol1, iModelCol2, iModelCol3);
    vec4 worldPos = model * vec4(aPos, 1.0);
    FragPos = worldPos.xyz;
    Normal = mat3(transpose(inverse(model))) * aNormal;
    TexCoord = aTexCoord;
    InstanceColor = iColor;
    FragPosLightSpace = lightSpaceMatrix * worldPos;
    gl_Position = projection * view * worldPos;
}
"#;

pub(super) const INSTANCED_FRAGMENT_SHADER_3D: &str = r#"
#version 330 core

in vec3 FragPos;
in vec3 Normal;
in vec2 TexCoord;
in vec4 InstanceColor;
in vec4 FragPosLightSpace;

out vec4 FragColor;

struct Light {
    int light_type;
    vec3 position;
    vec3 direction;
    vec3 color;
    float intensity;
    float range;
    float spotAngle;
    bool enabled;
};

uniform sampler2D texture1;
uniform sampler2D shadowMap;
uniform vec3 viewPos;
uniform int numLights;
uniform Light lights[8];
uniform bool useTexture;
uniform vec4 objectColor;
uniform bool fogEnabled;
uniform vec3 fogColor;
uniform float fogDensity;
uniform bool shadowsEnabled;
uniform float shadowBias;
uniform vec2 shadowTexelSize;

vec3 calculatePointLight(Light light, vec3 normal, vec3 fragPos, vec3 viewDir) {
    vec3 lightDir = normalize(light.position - fragPos);
    float distance = length(light.position - fragPos);
    float attenuation = 1.0 / (1.0 + 0.09 * distance + 0.032 * distance * distance);
    float diff = max(dot(normal, lightDir), 0.0);
    vec3 diffuse = diff * light.color;
    vec3 halfDir = normalize(lightDir + viewDir);
    float spec = pow(max(dot(normal, halfDir), 0.0), 64.0);
    vec3 specular = spec * light.color * 0.3;
    float rangeAttenuation = 1.0 - smoothstep(0.0, light.range, distance);
    return (diffuse + specular) * attenuation * rangeAttenuation * light.intensity;
}

vec3 calculateDirectionalLight(Light light, vec3 normal, vec3 viewDir) {
    vec3 lightDir = normalize(-light.direction);
    float diff = max(dot(normal, lightDir), 0.0);
    vec3 diffuse = diff * light.color;
    vec3 halfDir = normalize(lightDir + viewDir);
    float spec = pow(max(dot(normal, halfDir), 0.0), 64.0);
    vec3 specular = spec * light.color * 0.3;
    return (diffuse + specular) * light.intensity;
}

vec3 calculateSpotLight(Light light, vec3 normal, vec3 fragPos, vec3 viewDir) {
    vec3 lightDir = normalize(light.position - fragPos);
    float theta = dot(lightDir, normalize(-light.direction));
    float epsilon = cos(radians(light.spotAngle)) - cos(radians(light.spotAngle + 5.0));
    float intensity = clamp((theta - cos(radians(light.spotAngle + 5.0))) / epsilon, 0.0, 1.0);
    if (intensity > 0.0) {
        return calculatePointLight(light, normal, fragPos, viewDir) * intensity;
    }
    return vec3(0.0);
}

float calculateFog(float distance) {
    float fog = exp(-pow(fogDensity * distance, 2.0));
    return clamp(fog, 0.0, 1.0);
}

float calculateShadowFactor() {
    if (!shadowsEnabled) {
        return 0.0;
    }

    vec3 projCoords = FragPosLightSpace.xyz / max(FragPosLightSpace.w, 0.0001);
    projCoords = projCoords * 0.5 + 0.5;
    if (projCoords.x < 0.0 || projCoords.x > 1.0 || projCoords.y < 0.0 || projCoords.y > 1.0 || projCoords.z > 1.0) {
        return 0.0;
    }

    float currentDepth = projCoords.z;
    float shadow = 0.0;
    vec2 texelSize = shadowTexelSize;
    for (int x = -1; x <= 1; x++) {
        for (int y = -1; y <= 1; y++) {
            float closestDepth = texture(shadowMap, projCoords.xy + vec2(x, y) * texelSize).r;
            shadow += currentDepth - shadowBias > closestDepth ? 1.0 : 0.0;
        }
    }
    return shadow / 9.0;
}

void main() {
    vec3 norm = normalize(Normal);
    vec3 viewDir = normalize(viewPos - FragPos);
    vec3 result = vec3(0.1);

    for (int i = 0; i < numLights && i < 8; i++) {
        if (!lights[i].enabled) continue;

        vec3 lightContribution;
        if (lights[i].light_type == 0) {
            lightContribution = calculatePointLight(lights[i], norm, FragPos, viewDir);
        } else if (lights[i].light_type == 1) {
            lightContribution = calculateDirectionalLight(lights[i], norm, viewDir);
        } else {
            lightContribution = calculateSpotLight(lights[i], norm, FragPos, viewDir);
        }
        result += lightContribution;
    }

    vec4 baseColor = useTexture ? texture(texture1, TexCoord) : objectColor;
    baseColor *= InstanceColor;
    float shadow = calculateShadowFactor();
    vec3 finalColor = (1.0 - 0.65 * shadow) * result * baseColor.rgb;

    if (fogEnabled) {
        float distance = length(FragPos - viewPos);
        float visibility = calculateFog(distance);
        finalColor = mix(fogColor, finalColor, visibility);
    }

    FragColor = vec4(finalColor, baseColor.a);
}
"#;

pub(super) const GRID_VERTEX_SHADER: &str = r#"
#version 330 core

layout (location = 0) in vec3 aPos;
layout (location = 1) in vec3 aColor;

out vec3 vertexColor;
out vec3 fragPos;

uniform mat4 view;
uniform mat4 projection;

void main()
{
    fragPos = aPos;
    vertexColor = aColor;
    gl_Position = projection * view * vec4(aPos, 1.0);
}
"#;

pub(super) const GRID_FRAGMENT_SHADER: &str = r#"
#version 330 core

in vec3 vertexColor;
in vec3 fragPos;

out vec4 FragColor;

uniform vec3 viewPos;
uniform bool fogEnabled;
uniform vec3 fogColor;
uniform float fogDensity;
uniform float alpha;

void main()
{
    vec3 color = vertexColor;

    if (fogEnabled) {
        float distance = length(viewPos - fragPos);
        float fogFactor = exp(-fogDensity * distance);
        fogFactor = clamp(fogFactor, 0.0, 1.0);
        color = mix(fogColor, color, fogFactor);
    }

    FragColor = vec4(color, alpha);
}
"#;

// NOTE: The Uniforms struct is duplicated in each vertex/fragment shader pair because WGSL modules are self-contained. Layout changes must update all copies.
pub(super) const INSTANCED_VERTEX_SHADER_3D_WGSL: &str = r#"
struct Light {
    light_type: i32,
    position: vec3<f32>,
    direction: vec3<f32>,
    color: vec3<f32>,
    intensity: f32,
    range: f32,
    spotAngle: f32,
    enabled: i32,
}

struct Uniforms {
    view: mat4x4<f32>,
    projection: mat4x4<f32>,
    lightSpaceMatrix: mat4x4<f32>,
    viewPos: vec3<f32>,
    fogDensity: f32,
    objectColor: vec4<f32>,
    fogColor: vec3<f32>,
    numLights: i32,
    useTexture: i32,
    shadowsEnabled: i32,
    fogEnabled: i32,
    shadowBias: f32,
    shadowTexelSize: vec2<f32>,
    _pad3: f32,
    primaryLightDir: vec3<f32>,
    primaryLightIntensity: f32,
    primaryLightColor: vec3<f32>,
    _pad4: f32,
    lights: array<Light, 8>,
}

@group(0) @binding(0) var<uniform> uniforms: Uniforms;

struct VertexInput {
    @location(0) position: vec3<f32>,
    @location(1) normal: vec3<f32>,
    @location(2) tex_coord: vec2<f32>,
    @location(3) model_0: vec4<f32>,
    @location(4) model_1: vec4<f32>,
    @location(5) model_2: vec4<f32>,
    @location(6) model_3: vec4<f32>,
    @location(7) color: vec4<f32>,
};

struct VertexOutput {
    @builtin(position) clip_position: vec4<f32>,
    @location(0) frag_pos: vec3<f32>,
    @location(1) normal: vec3<f32>,
    @location(2) tex_coord: vec2<f32>,
    @location(3) inst_color: vec4<f32>,
    @location(4) frag_pos_light_space: vec4<f32>,
};

@vertex
fn main(input: VertexInput) -> VertexOutput {
    let model = mat4x4<f32>(input.model_0, input.model_1, input.model_2, input.model_3);
    let world_pos = model * vec4<f32>(input.position, 1.0);
    var output: VertexOutput;
    output.clip_position = uniforms.projection * uniforms.view * world_pos;
    output.frag_pos = world_pos.xyz;
    output.normal = (model * vec4<f32>(input.normal, 0.0)).xyz;
    output.tex_coord = input.tex_coord;
    output.inst_color = input.color;
    output.frag_pos_light_space = uniforms.lightSpaceMatrix * world_pos;
    return output;
}
"#;

pub(super) const INSTANCED_FRAGMENT_SHADER_3D_WGSL: &str = r#"
struct Light {
    light_type: i32,
    position: vec3<f32>,
    direction: vec3<f32>,
    color: vec3<f32>,
    intensity: f32,
    range: f32,
    spotAngle: f32,
    enabled: i32,
}

struct Uniforms {
    view: mat4x4<f32>,
    projection: mat4x4<f32>,
    lightSpaceMatrix: mat4x4<f32>,
    viewPos: vec3<f32>,
    fogDensity: f32,
    objectColor: vec4<f32>,
    fogColor: vec3<f32>,
    numLights: i32,
    useTexture: i32,
    shadowsEnabled: i32,
    fogEnabled: i32,
    shadowBias: f32,
    shadowTexelSize: vec2<f32>,
    _pad3: f32,
    primaryLightDir: vec3<f32>,
    primaryLightIntensity: f32,
    primaryLightColor: vec3<f32>,
    _pad4: f32,
    lights: array<Light, 8>,
}

@group(0) @binding(0) var<uniform> uniforms: Uniforms;
@group(1) @binding(0) var u_texture: texture_2d<f32>;
@group(1) @binding(1) var u_sampler: sampler;
@group(3) @binding(0) var shadow_map: texture_depth_2d;
@group(3) @binding(1) var shadow_sampler: sampler_comparison;

fn calculate_point_light(light: Light, normal: vec3<f32>, frag_pos: vec3<f32>, view_dir: vec3<f32>) -> vec3<f32> {
    let light_dir = normalize(light.position - frag_pos);
    let distance = length(light.position - frag_pos);
    let attenuation = 1.0 / (1.0 + 0.09 * distance + 0.032 * distance * distance);
    let diff = max(dot(normal, light_dir), 0.0);
    let diffuse = diff * light.color;
    let half_dir = normalize(light_dir + view_dir);
    let spec = pow(max(dot(normal, half_dir), 0.0), 64.0);
    let specular = spec * light.color * 0.3;
    let range_atten = 1.0 - smoothstep(0.0, light.range, distance);
    return (diffuse + specular) * attenuation * range_atten * light.intensity;
}

fn calculate_directional_light(light: Light, normal: vec3<f32>, view_dir: vec3<f32>) -> vec3<f32> {
    let light_dir = normalize(-light.direction);
    let diff = max(dot(normal, light_dir), 0.0);
    let diffuse = diff * light.color;
    let half_dir = normalize(light_dir + view_dir);
    let spec = pow(max(dot(normal, half_dir), 0.0), 64.0);
    let specular = spec * light.color * 0.3;
    return (diffuse + specular) * light.intensity;
}

fn calculate_spot_light(light: Light, normal: vec3<f32>, frag_pos: vec3<f32>, view_dir: vec3<f32>) -> vec3<f32> {
    let light_dir = normalize(light.position - frag_pos);
    let theta = dot(light_dir, normalize(-light.direction));
    let outer_cos = cos(radians(light.spotAngle + 5.0));
    let inner_cos = cos(radians(light.spotAngle));
    let epsilon = inner_cos - outer_cos;
    let spot_intensity = clamp((theta - outer_cos) / epsilon, 0.0, 1.0);
    if spot_intensity > 0.0 {
        return calculate_point_light(light, normal, frag_pos, view_dir) * spot_intensity;
    }
    return vec3<f32>(0.0);
}

fn calculate_shadow_factor(frag_pos_ls: vec4<f32>) -> f32 {
    if uniforms.shadowsEnabled == 0 {
        return 0.0;
    }
    let proj_coords = frag_pos_ls.xyz / frag_pos_ls.w;
    let uv = proj_coords.xy * 0.5 + 0.5;
    let uv_flipped = vec2(uv.x, 1.0 - uv.y);

    if uv_flipped.x < 0.0 || uv_flipped.x > 1.0 || uv_flipped.y < 0.0 || uv_flipped.y > 1.0 || proj_coords.z > 1.0 {
        return 0.0;
    }

    let current_depth = proj_coords.z;
    let bias = uniforms.shadowBias;
    let texel = uniforms.shadowTexelSize;
    var shadow = 0.0;
    for (var x: i32 = -1; x <= 1; x++) {
        for (var y: i32 = -1; y <= 1; y++) {
            let offset = vec2(f32(x), f32(y)) * texel;
            shadow += textureSampleCompare(shadow_map, shadow_sampler, uv_flipped + offset, current_depth - bias);
        }
    }
    return 1.0 - shadow / 9.0;
}

@fragment
fn main(
    @location(0) frag_pos: vec3<f32>,
    @location(1) normal: vec3<f32>,
    @location(2) tex_coord: vec2<f32>,
    @location(3) inst_color: vec4<f32>,
    @location(4) frag_pos_light_space: vec4<f32>,
) -> @location(0) vec4<f32> {
    let norm = normalize(normal);
    let view_dir = normalize(uniforms.viewPos - frag_pos);

    var result = vec3<f32>(0.1);

    var light_count = uniforms.numLights;
    if light_count > 8 {
        light_count = 8;
    }

    if light_count > 0 {
        for (var i = 0; i < light_count; i = i + 1) {
            if uniforms.lights[i].enabled == 0 {
                continue;
            }
            var contribution: vec3<f32>;
            if uniforms.lights[i].light_type == 0 {
                contribution = calculate_point_light(uniforms.lights[i], norm, frag_pos, view_dir);
            } else if uniforms.lights[i].light_type == 1 {
                contribution = calculate_directional_light(uniforms.lights[i], norm, view_dir);
            } else {
                contribution = calculate_spot_light(uniforms.lights[i], norm, frag_pos, view_dir);
            }
            result = result + contribution;
        }
    } else {
        // Fallback to primary light when no structured lights are provided
        var light_dir: vec3<f32>;
        var light_color: vec3<f32>;
        var light_i: f32;
        if uniforms.primaryLightIntensity > 0.0 {
            light_dir = normalize(uniforms.primaryLightDir);
            light_color = uniforms.primaryLightColor;
            light_i = uniforms.primaryLightIntensity;
        } else {
            light_dir = normalize(vec3<f32>(0.3, 1.0, 0.5));
            light_color = vec3<f32>(1.0, 1.0, 1.0);
            light_i = 1.0;
        }
        let diff = max(dot(norm, light_dir), 0.0);
        let half_dir = normalize(light_dir + view_dir);
        let spec = pow(max(dot(norm, half_dir), 0.0), 64.0) * 0.3;
        result = vec3<f32>(0.1) + (diff + spec) * light_color * light_i;
    }

    var base_color: vec4<f32>;
    if uniforms.useTexture != 0 {
        base_color = textureSample(u_texture, u_sampler, tex_coord);
    } else {
        base_color = uniforms.objectColor;
    }
    base_color = base_color * inst_color;

    let shadow = calculate_shadow_factor(frag_pos_light_space);
    var final_color = (1.0 - 0.65 * shadow) * result * base_color.rgb;

    if uniforms.fogEnabled != 0 {
        let dist = length(frag_pos - uniforms.viewPos);
        let fog_factor = clamp(exp(-pow(uniforms.fogDensity * dist, 2.0)), 0.0, 1.0);
        final_color = mix(uniforms.fogColor, final_color, fog_factor);
    }

    return vec4<f32>(final_color, base_color.a);
}
"#;

pub(super) const VERTEX_SHADER_3D_WGSL: &str = r#"
struct Light {
    light_type: i32,
    position: vec3<f32>,
    direction: vec3<f32>,
    color: vec3<f32>,
    intensity: f32,
    range: f32,
    spotAngle: f32,
    enabled: i32,
}

struct Uniforms {
    model: mat4x4<f32>,
    view: mat4x4<f32>,
    projection: mat4x4<f32>,
    lightSpaceMatrix: mat4x4<f32>,
    viewPos: vec3<f32>,
    fogDensity: f32,
    objectColor: vec4<f32>,
    fogColor: vec3<f32>,
    numLights: i32,
    useTexture: i32,
    shadowsEnabled: i32,
    fogEnabled: i32,
    shadowBias: f32,
    shadowTexelSize: vec2<f32>,
    _pad3: f32,
    primaryLightDir: vec3<f32>,
    primaryLightIntensity: f32,
    primaryLightColor: vec3<f32>,
    _pad4: f32,
    lights: array<Light, 8>,
}

@group(0) @binding(0) var<uniform> uniforms: Uniforms;

struct VertexInput {
    @location(0) position: vec3<f32>,
    @location(1) normal: vec3<f32>,
    @location(2) tex_coord: vec2<f32>,
};

struct VertexOutput {
    @builtin(position) clip_position: vec4<f32>,
    @location(0) frag_pos: vec3<f32>,
    @location(1) normal: vec3<f32>,
    @location(2) tex_coord: vec2<f32>,
    @location(3) frag_pos_light_space: vec4<f32>,
};

@vertex
fn main(input: VertexInput) -> VertexOutput {
    let world_pos = uniforms.model * vec4<f32>(input.position, 1.0);
    var output: VertexOutput;
    output.clip_position = uniforms.projection * uniforms.view * world_pos;
    output.frag_pos = world_pos.xyz;
    output.normal = (uniforms.model * vec4<f32>(input.normal, 0.0)).xyz;
    output.tex_coord = input.tex_coord;
    output.frag_pos_light_space = uniforms.lightSpaceMatrix * world_pos;
    return output;
}
"#;

pub(super) const FRAGMENT_SHADER_3D_WGSL: &str = r#"
struct Light {
    light_type: i32,
    position: vec3<f32>,
    direction: vec3<f32>,
    color: vec3<f32>,
    intensity: f32,
    range: f32,
    spotAngle: f32,
    enabled: i32,
}

struct Uniforms {
    model: mat4x4<f32>,
    view: mat4x4<f32>,
    projection: mat4x4<f32>,
    lightSpaceMatrix: mat4x4<f32>,
    viewPos: vec3<f32>,
    fogDensity: f32,
    objectColor: vec4<f32>,
    fogColor: vec3<f32>,
    numLights: i32,
    useTexture: i32,
    shadowsEnabled: i32,
    fogEnabled: i32,
    shadowBias: f32,
    shadowTexelSize: vec2<f32>,
    _pad3: f32,
    primaryLightDir: vec3<f32>,
    primaryLightIntensity: f32,
    primaryLightColor: vec3<f32>,
    _pad4: f32,
    lights: array<Light, 8>,
}

@group(0) @binding(0) var<uniform> uniforms: Uniforms;
@group(1) @binding(0) var u_texture: texture_2d<f32>;
@group(1) @binding(1) var u_sampler: sampler;
@group(3) @binding(0) var shadow_map: texture_depth_2d;
@group(3) @binding(1) var shadow_sampler: sampler_comparison;

fn calculate_point_light(light: Light, normal: vec3<f32>, frag_pos: vec3<f32>, view_dir: vec3<f32>) -> vec3<f32> {
    let light_dir = normalize(light.position - frag_pos);
    let distance = length(light.position - frag_pos);
    let attenuation = 1.0 / (1.0 + 0.09 * distance + 0.032 * distance * distance);
    let diff = max(dot(normal, light_dir), 0.0);
    let diffuse = diff * light.color;
    let half_dir = normalize(light_dir + view_dir);
    let spec = pow(max(dot(normal, half_dir), 0.0), 64.0);
    let specular = spec * light.color * 0.3;
    let range_atten = 1.0 - smoothstep(0.0, light.range, distance);
    return (diffuse + specular) * attenuation * range_atten * light.intensity;
}

fn calculate_directional_light(light: Light, normal: vec3<f32>, view_dir: vec3<f32>) -> vec3<f32> {
    let light_dir = normalize(-light.direction);
    let diff = max(dot(normal, light_dir), 0.0);
    let diffuse = diff * light.color;
    let half_dir = normalize(light_dir + view_dir);
    let spec = pow(max(dot(normal, half_dir), 0.0), 64.0);
    let specular = spec * light.color * 0.3;
    return (diffuse + specular) * light.intensity;
}

fn calculate_spot_light(light: Light, normal: vec3<f32>, frag_pos: vec3<f32>, view_dir: vec3<f32>) -> vec3<f32> {
    let light_dir = normalize(light.position - frag_pos);
    let theta = dot(light_dir, normalize(-light.direction));
    let outer_cos = cos(radians(light.spotAngle + 5.0));
    let inner_cos = cos(radians(light.spotAngle));
    let epsilon = inner_cos - outer_cos;
    let spot_intensity = clamp((theta - outer_cos) / epsilon, 0.0, 1.0);
    if spot_intensity > 0.0 {
        return calculate_point_light(light, normal, frag_pos, view_dir) * spot_intensity;
    }
    return vec3<f32>(0.0);
}

fn calculate_shadow_factor(frag_pos_ls: vec4<f32>) -> f32 {
    if uniforms.shadowsEnabled == 0 {
        return 0.0;
    }
    let proj_coords = frag_pos_ls.xyz / frag_pos_ls.w;
    let uv = proj_coords.xy * 0.5 + 0.5;
    let uv_flipped = vec2(uv.x, 1.0 - uv.y);

    if uv_flipped.x < 0.0 || uv_flipped.x > 1.0 || uv_flipped.y < 0.0 || uv_flipped.y > 1.0 || proj_coords.z > 1.0 {
        return 0.0;
    }

    let current_depth = proj_coords.z;
    let bias = uniforms.shadowBias;
    let texel = uniforms.shadowTexelSize;
    var shadow = 0.0;
    for (var x: i32 = -1; x <= 1; x++) {
        for (var y: i32 = -1; y <= 1; y++) {
            let offset = vec2(f32(x), f32(y)) * texel;
            shadow += textureSampleCompare(shadow_map, shadow_sampler, uv_flipped + offset, current_depth - bias);
        }
    }
    return 1.0 - shadow / 9.0;
}

@fragment
fn main(
    @location(0) frag_pos: vec3<f32>,
    @location(1) normal: vec3<f32>,
    @location(2) tex_coord: vec2<f32>,
    @location(3) frag_pos_light_space: vec4<f32>,
) -> @location(0) vec4<f32> {
    let norm = normalize(normal);
    let view_dir = normalize(uniforms.viewPos - frag_pos);

    var result = vec3<f32>(0.1);

    var light_count = uniforms.numLights;
    if light_count > 8 {
        light_count = 8;
    }

    if light_count > 0 {
        for (var i = 0; i < light_count; i = i + 1) {
            if uniforms.lights[i].enabled == 0 {
                continue;
            }
            var contribution: vec3<f32>;
            if uniforms.lights[i].light_type == 0 {
                contribution = calculate_point_light(uniforms.lights[i], norm, frag_pos, view_dir);
            } else if uniforms.lights[i].light_type == 1 {
                contribution = calculate_directional_light(uniforms.lights[i], norm, view_dir);
            } else {
                contribution = calculate_spot_light(uniforms.lights[i], norm, frag_pos, view_dir);
            }
            result = result + contribution;
        }
    } else {
        // Fallback to primary light when no structured lights are provided
        var light_dir: vec3<f32>;
        var light_color: vec3<f32>;
        var light_i: f32;
        if uniforms.primaryLightIntensity > 0.0 {
            light_dir = normalize(uniforms.primaryLightDir);
            light_color = uniforms.primaryLightColor;
            light_i = uniforms.primaryLightIntensity;
        } else {
            light_dir = normalize(vec3<f32>(0.3, 1.0, 0.5));
            light_color = vec3<f32>(1.0, 1.0, 1.0);
            light_i = 1.0;
        }
        let diff = max(dot(norm, light_dir), 0.0);
        let half_dir = normalize(light_dir + view_dir);
        let spec = pow(max(dot(norm, half_dir), 0.0), 64.0) * 0.3;
        result = vec3<f32>(0.1) + (diff + spec) * light_color * light_i;
    }

    var base_color: vec4<f32>;
    if uniforms.useTexture != 0 {
        base_color = textureSample(u_texture, u_sampler, tex_coord);
    } else {
        base_color = uniforms.objectColor;
    }

    let shadow = calculate_shadow_factor(frag_pos_light_space);
    var final_color = (1.0 - 0.65 * shadow) * result * base_color.rgb;

    if uniforms.fogEnabled != 0 {
        let dist = length(frag_pos - uniforms.viewPos);
        let fog_factor = clamp(exp(-pow(uniforms.fogDensity * dist, 2.0)), 0.0, 1.0);
        final_color = mix(uniforms.fogColor, final_color, fog_factor);
    }

    return vec4<f32>(final_color, base_color.a);
}
"#;

pub(super) const GRID_VERTEX_SHADER_WGSL: &str = r#"
struct Uniforms {
    view: mat4x4<f32>,
    projection: mat4x4<f32>,
    viewPos: vec3<f32>,
    fogDensity: f32,
    fogColor: vec3<f32>,
    fogEnabled: i32,
    alpha: f32,
}

@group(0) @binding(0) var<uniform> uniforms: Uniforms;

struct VertexInput {
    @location(0) position: vec3<f32>,
    @location(1) color: vec3<f32>,
};

struct VertexOutput {
    @builtin(position) clip_position: vec4<f32>,
    @location(0) color: vec3<f32>,
    @location(1) frag_pos: vec3<f32>,
};

@vertex
fn main(input: VertexInput) -> VertexOutput {
    var output: VertexOutput;
    output.clip_position = uniforms.projection * uniforms.view * vec4<f32>(input.position, 1.0);
    output.color = input.color;
    output.frag_pos = input.position;
    return output;
}
"#;

pub(super) const GRID_FRAGMENT_SHADER_WGSL: &str = r#"
struct Uniforms {
    view: mat4x4<f32>,
    projection: mat4x4<f32>,
    viewPos: vec3<f32>,
    fogDensity: f32,
    fogColor: vec3<f32>,
    fogEnabled: i32,
    alpha: f32,
}

@group(0) @binding(0) var<uniform> uniforms: Uniforms;

@fragment
fn main(
    @location(0) color: vec3<f32>,
    @location(1) frag_pos: vec3<f32>,
) -> @location(0) vec4<f32> {
    var final_color = color;

    if uniforms.fogEnabled != 0 {
        let dist = length(uniforms.viewPos - frag_pos);
        let fog_factor = clamp(exp(-pow(uniforms.fogDensity * dist, 2.0)), 0.0, 1.0);
        final_color = mix(uniforms.fogColor, final_color, fog_factor);
    }

    return vec4<f32>(final_color, uniforms.alpha);
}
"#;

pub(super) const POSTPROCESS_VERTEX_SHADER: &str = r#"
#version 330 core
layout (location = 0) in vec2 aPos;
layout (location = 1) in vec2 aTexCoord;
out vec2 TexCoord;
void main() {
    TexCoord = aTexCoord;
    gl_Position = vec4(aPos, 0.0, 1.0);
}
"#;

pub(super) const POSTPROCESS_FRAGMENT_SHADER: &str = r#"
#version 330 core
in vec2 TexCoord;
out vec4 FragColor;
uniform sampler2D screenTexture;
void main() {
    FragColor = texture(screenTexture, TexCoord);
}
"#;

pub(super) const POSTPROCESS_VERTEX_SHADER_WGSL: &str = r#"
struct VertexInput {
    @location(0) position: vec2<f32>,
    @location(1) tex_coord: vec2<f32>,
};
struct VertexOutput {
    @builtin(position) clip_position: vec4<f32>,
    @location(0) tex_coord: vec2<f32>,
};
@vertex
fn main(input: VertexInput) -> VertexOutput {
    var output: VertexOutput;
    output.clip_position = vec4<f32>(input.position, 0.0, 1.0);
    output.tex_coord = input.tex_coord;
    return output;
}
"#;

pub(super) const POSTPROCESS_FRAGMENT_SHADER_WGSL: &str = r#"
@group(1) @binding(0) var screen_texture: texture_2d<f32>;
@group(1) @binding(1) var screen_sampler: sampler;
@fragment
fn main(@location(0) tex_coord: vec2<f32>) -> @location(0) vec4<f32> {
    return textureSample(screen_texture, screen_sampler, tex_coord);
}
"#;

#[allow(dead_code)]
pub(super) const PBR_FRAGMENT_SHADER: &str = r#"
#version 330 core

in vec3 FragPos;
in vec3 Normal;
in vec2 TexCoord;

out vec4 FragColor;

struct Light {
    int light_type;
    vec3 position;
    vec3 direction;
    vec3 color;
    float intensity;
    float range;
    float spotAngle;
    bool enabled;
};

uniform vec3 viewPos;
uniform int numLights;
uniform Light lights[8];
uniform vec3 albedo;
uniform float metallic;
uniform float roughness;
uniform float ao;

const float PI = 3.14159265359;

float distributionGGX(vec3 N, vec3 H, float r) {
    float a = r * r;
    float a2 = a * a;
    float NdotH = max(dot(N, H), 0.0);
    float denom = NdotH * NdotH * (a2 - 1.0) + 1.0;
    return a2 / (PI * denom * denom);
}

float geometrySchlickGGX(float NdotV, float r) {
    float k = (r + 1.0) * (r + 1.0) / 8.0;
    return NdotV / (NdotV * (1.0 - k) + k);
}

float geometrySmith(vec3 N, vec3 V, vec3 L, float r) {
    return geometrySchlickGGX(max(dot(N, V), 0.0), r)
         * geometrySchlickGGX(max(dot(N, L), 0.0), r);
}

vec3 fresnelSchlick(float cosTheta, vec3 F0) {
    return F0 + (1.0 - F0) * pow(clamp(1.0 - cosTheta, 0.0, 1.0), 5.0);
}

void main() {
    vec3 N = normalize(Normal);
    vec3 V = normalize(viewPos - FragPos);
    vec3 F0 = mix(vec3(0.04), albedo, metallic);

    vec3 Lo = vec3(0.0);
    for (int i = 0; i < numLights && i < 8; i++) {
        if (!lights[i].enabled) continue;

        vec3 L;
        float attenuation = 1.0;
        if (lights[i].light_type == 1) {
            L = normalize(-lights[i].direction);
        } else {
            L = normalize(lights[i].position - FragPos);
            float d = length(lights[i].position - FragPos);
            attenuation = 1.0 / (d * d + 1.0);
        }

        vec3 H = normalize(V + L);
        vec3 radiance = lights[i].color * lights[i].intensity * attenuation;

        float NDF = distributionGGX(N, H, roughness);
        float G = geometrySmith(N, V, L, roughness);
        vec3 F = fresnelSchlick(max(dot(H, V), 0.0), F0);

        vec3 num = NDF * G * F;
        float denom = 4.0 * max(dot(N, V), 0.0) * max(dot(N, L), 0.0) + 0.0001;
        vec3 specular = num / denom;

        vec3 kD = (vec3(1.0) - F) * (1.0 - metallic);
        float NdotL = max(dot(N, L), 0.0);
        Lo += (kD * albedo / PI + specular) * radiance * NdotL;
    }

    vec3 ambient = vec3(0.03) * albedo * ao;
    vec3 color = ambient + Lo;
    color = color / (color + vec3(1.0));
    color = pow(color, vec3(1.0 / 2.2));
    FragColor = vec4(color, 1.0);
}
"#;

pub(super) const SKINNED_VERTEX_SHADER: &str = r#"
#version 330 core

layout (location = 0) in vec3 aPos;
layout (location = 1) in vec3 aNormal;
layout (location = 2) in vec2 aTexCoord;
layout (location = 3) in vec4 aBoneIds;
layout (location = 4) in vec4 aBoneWeights;

out vec3 FragPos;
out vec3 Normal;
out vec2 TexCoord;
out vec4 FragPosLightSpace;

uniform mat4 model;
uniform mat4 view;
uniform mat4 projection;
uniform mat4 lightSpaceMatrix;
uniform mat4 boneMatrices[128];
uniform int boneOffset;

void main() {
    ivec4 boneIdx = ivec4(aBoneIds);
    int base = boneOffset;
    mat4 skinMatrix = aBoneWeights.x * boneMatrices[base + boneIdx.x]
                    + aBoneWeights.y * boneMatrices[base + boneIdx.y]
                    + aBoneWeights.z * boneMatrices[base + boneIdx.z]
                    + aBoneWeights.w * boneMatrices[base + boneIdx.w];
    vec4 skinnedPos = skinMatrix * vec4(aPos, 1.0);
    FragPos = vec3(model * skinnedPos);
    Normal = mat3(transpose(inverse(model * skinMatrix))) * aNormal;
    TexCoord = aTexCoord;
    FragPosLightSpace = lightSpaceMatrix * vec4(FragPos, 1.0);
    gl_Position = projection * view * vec4(FragPos, 1.0);
}
"#;

// NOTE: The Uniforms struct matches the main 3D vertex shader since the
// skinned shader shares the same fragment shader (FRAGMENT_SHADER_3D_WGSL).
// Bone matrices are read from a storage buffer at @group(2) @binding(0).
pub(super) const SKINNED_VERTEX_SHADER_WGSL: &str = r#"
struct Light {
    light_type: i32,
    position: vec3<f32>,
    direction: vec3<f32>,
    color: vec3<f32>,
    intensity: f32,
    range: f32,
    spotAngle: f32,
    enabled: i32,
}

struct Uniforms {
    model: mat4x4<f32>,
    view: mat4x4<f32>,
    projection: mat4x4<f32>,
    lightSpaceMatrix: mat4x4<f32>,
    viewPos: vec3<f32>,
    fogDensity: f32,
    objectColor: vec4<f32>,
    fogColor: vec3<f32>,
    numLights: i32,
    useTexture: i32,
    shadowsEnabled: i32,
    fogEnabled: i32,
    shadowBias: f32,
    boneOffset: i32,
    shadowTexelSize: vec2<f32>,
    primaryLightDir: vec3<f32>,
    primaryLightIntensity: f32,
    primaryLightColor: vec3<f32>,
    _pad4: f32,
    lights: array<Light, 8>,
}

@group(0) @binding(0) var<uniform> uniforms: Uniforms;
@group(2) @binding(0) var<storage, read> boneMatrices: array<mat4x4<f32>>;

struct VertexInput {
    @location(0) position: vec3<f32>,
    @location(1) normal: vec3<f32>,
    @location(2) tex_coord: vec2<f32>,
    @location(3) bone_ids: vec4<f32>,
    @location(4) bone_weights: vec4<f32>,
};

struct VertexOutput {
    @builtin(position) clip_position: vec4<f32>,
    @location(0) frag_pos: vec3<f32>,
    @location(1) normal: vec3<f32>,
    @location(2) tex_coord: vec2<f32>,
    @location(3) frag_pos_light_space: vec4<f32>,
};

@vertex
fn main(input: VertexInput) -> VertexOutput {
    let bone_idx = vec4<i32>(input.bone_ids);
    let w = input.bone_weights;
    let base = uniforms.boneOffset;

    // Compute skinning matrix from weighted bone transforms.
    var skin_matrix = w.x * boneMatrices[base + bone_idx.x]
                    + w.y * boneMatrices[base + bone_idx.y]
                    + w.z * boneMatrices[base + bone_idx.z]
                    + w.w * boneMatrices[base + bone_idx.w];

    let skinned_pos = skin_matrix * vec4<f32>(input.position, 1.0);
    let world_pos = uniforms.model * skinned_pos;

    // Transform normal through the skinning matrix (upper 3x3).
    let skinned_normal = (skin_matrix * vec4<f32>(input.normal, 0.0)).xyz;
    let world_normal = (uniforms.model * vec4<f32>(skinned_normal, 0.0)).xyz;

    var output: VertexOutput;
    output.clip_position = uniforms.projection * uniforms.view * world_pos;
    output.frag_pos = world_pos.xyz;
    output.normal = world_normal;
    output.tex_coord = input.tex_coord;
    output.frag_pos_light_space = uniforms.lightSpaceMatrix * world_pos;
    return output;
}
"#;

pub(super) const INSTANCED_SKINNED_VERTEX_SHADER: &str = r#"
#version 330 core

layout (location = 0) in vec3 aPos;
layout (location = 1) in vec3 aNormal;
layout (location = 2) in vec2 aTexCoord;
layout (location = 3) in vec4 aBoneIds;
layout (location = 4) in vec4 aBoneWeights;
// Per-instance attributes
layout (location = 5) in vec4 iModelCol0;
layout (location = 6) in vec4 iModelCol1;
layout (location = 7) in vec4 iModelCol2;
layout (location = 8) in vec4 iModelCol3;
layout (location = 9) in float iBoneOffset;
layout (location = 10) in vec4 iColor;

out vec3 FragPos;
out vec3 Normal;
out vec2 TexCoord;
out vec4 InstanceColor;
out vec4 FragPosLightSpace;

uniform mat4 view;
uniform mat4 projection;
uniform mat4 lightSpaceMatrix;
uniform mat4 boneMatrices[128];

void main() {
    mat4 model = mat4(iModelCol0, iModelCol1, iModelCol2, iModelCol3);
    ivec4 boneIdx = ivec4(aBoneIds);
    int base = int(iBoneOffset);
    mat4 skinMatrix = aBoneWeights.x * boneMatrices[base + boneIdx.x]
                    + aBoneWeights.y * boneMatrices[base + boneIdx.y]
                    + aBoneWeights.z * boneMatrices[base + boneIdx.z]
                    + aBoneWeights.w * boneMatrices[base + boneIdx.w];
    vec4 skinnedPos = skinMatrix * vec4(aPos, 1.0);
    vec4 worldPos = model * skinnedPos;
    FragPos = worldPos.xyz;
    Normal = mat3(transpose(inverse(model * skinMatrix))) * aNormal;
    TexCoord = aTexCoord;
    InstanceColor = iColor;
    FragPosLightSpace = lightSpaceMatrix * worldPos;
    gl_Position = projection * view * worldPos;
}
"#;

pub(super) const INSTANCED_SKINNED_VERTEX_SHADER_WGSL: &str = r#"
struct Light {
    light_type: i32,
    position: vec3<f32>,
    direction: vec3<f32>,
    color: vec3<f32>,
    intensity: f32,
    range: f32,
    spotAngle: f32,
    enabled: i32,
}

struct Uniforms {
    view: mat4x4<f32>,
    projection: mat4x4<f32>,
    lightSpaceMatrix: mat4x4<f32>,
    viewPos: vec3<f32>,
    fogDensity: f32,
    objectColor: vec4<f32>,
    fogColor: vec3<f32>,
    numLights: i32,
    useTexture: i32,
    shadowsEnabled: i32,
    fogEnabled: i32,
    shadowBias: f32,
    shadowTexelSize: vec2<f32>,
    _pad3: f32,
    primaryLightDir: vec3<f32>,
    primaryLightIntensity: f32,
    primaryLightColor: vec3<f32>,
    _pad4: f32,
    lights: array<Light, 8>,
}

@group(0) @binding(0) var<uniform> uniforms: Uniforms;
@group(2) @binding(0) var<storage, read> boneMatrices: array<mat4x4<f32>>;

struct VertexInput {
    @location(0) position: vec3<f32>,
    @location(1) normal: vec3<f32>,
    @location(2) tex_coord: vec2<f32>,
    @location(3) bone_ids: vec4<f32>,
    @location(4) bone_weights: vec4<f32>,
    // Per-instance attributes
    @location(5) model_0: vec4<f32>,
    @location(6) model_1: vec4<f32>,
    @location(7) model_2: vec4<f32>,
    @location(8) model_3: vec4<f32>,
    @location(9) bone_offset: f32,
    @location(10) color: vec4<f32>,
};

struct VertexOutput {
    @builtin(position) clip_position: vec4<f32>,
    @location(0) frag_pos: vec3<f32>,
    @location(1) normal: vec3<f32>,
    @location(2) tex_coord: vec2<f32>,
    @location(3) inst_color: vec4<f32>,
    @location(4) frag_pos_light_space: vec4<f32>,
};

@vertex
fn main(input: VertexInput) -> VertexOutput {
    let model = mat4x4<f32>(input.model_0, input.model_1, input.model_2, input.model_3);
    let bone_idx = vec4<i32>(input.bone_ids);
    let base = i32(input.bone_offset);
    let w = input.bone_weights;

    var skin_matrix = w.x * boneMatrices[base + bone_idx.x]
                    + w.y * boneMatrices[base + bone_idx.y]
                    + w.z * boneMatrices[base + bone_idx.z]
                    + w.w * boneMatrices[base + bone_idx.w];

    let skinned_pos = skin_matrix * vec4<f32>(input.position, 1.0);
    let world_pos = model * skinned_pos;
    let skinned_normal = (skin_matrix * vec4<f32>(input.normal, 0.0)).xyz;
    let world_normal = (model * vec4<f32>(skinned_normal, 0.0)).xyz;

    var output: VertexOutput;
    output.clip_position = uniforms.projection * uniforms.view * world_pos;
    output.frag_pos = world_pos.xyz;
    output.normal = world_normal;
    output.tex_coord = input.tex_coord;
    output.inst_color = input.color;
    output.frag_pos_light_space = uniforms.lightSpaceMatrix * world_pos;
    return output;
}
"#;

#[allow(dead_code)]
pub(super) const PBR_FRAGMENT_SHADER_WGSL: &str = r#"
@fragment
fn main(@location(0) normal: vec3<f32>) -> @location(0) vec4<f32> {
    let lit = 0.35 + 0.65 * abs(normalize(normal).z);
    return vec4<f32>(lit, lit, lit, 1.0);
}
"#;

/// Depth-only vertex shader for the GPU shadow pre-pass.
///
/// Transforms vertices by a single MVP matrix. No fragment output is needed;
/// wgpu writes depth automatically when no fragment stage is attached.
pub(super) const DEPTH_ONLY_VERTEX_SHADER_WGSL: &str = r#"
struct Uniforms {
    mvp: mat4x4<f32>,
}

@group(0) @binding(0) var<uniform> uniforms: Uniforms;

struct VertexInput {
    @location(0) position: vec3<f32>,
};

struct VertexOutput {
    @builtin(position) clip_position: vec4<f32>,
};

@vertex
fn main(input: VertexInput) -> VertexOutput {
    var output: VertexOutput;
    output.clip_position = uniforms.mvp * vec4<f32>(input.position, 1.0);
    return output;
}
"#;

/// Depth-only GLSL vertex shader for the GPU shadow pre-pass (legacy OpenGL path).
pub(super) const DEPTH_ONLY_VERTEX_SHADER: &str = r#"
#version 330 core
layout (location = 0) in vec3 aPos;
uniform mat4 mvp;
void main() {
    gl_Position = mvp * vec4(aPos, 1.0);
}
"#;

/// Depth-only GLSL fragment shader (legacy OpenGL path).
pub(super) const DEPTH_ONLY_FRAGMENT_SHADER: &str = r#"
#version 330 core
void main() {}
"#;

/// Depth-only WGSL fragment shader -- empty; wgpu writes depth with no fragment stage.
/// This exists only for the GLSL transpile path which requires a fragment shader.
pub(super) const DEPTH_ONLY_FRAGMENT_SHADER_WGSL: &str = r#"
@fragment
fn main() {}
"#;
