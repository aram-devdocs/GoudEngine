#!/bin/sh
# Pre-push: comprehensive checks mirroring GitHub Actions CI
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 1

echo "=============================================="
echo "  Pre-push: Comprehensive Checks"
echo "=============================================="

# =============================================================================
# Format Check (mirrors: ci.yml cargo fmt --check)
# =============================================================================
echo ""
echo "=== [1/9] Checking formatting ==="
cargo fmt --all -- --check || exit 1

# =============================================================================
# Clippy (mirrors: ci.yml clippy --all-targets --all-features)
# =============================================================================
echo ""
echo "=== [2/9] Running clippy ==="
cargo clippy --all-targets --all-features -- -D warnings || exit 1

# =============================================================================
# Build (mirrors: ci.yml cargo build --verbose)
# =============================================================================
echo ""
echo "=== [3/9] Building ==="
cargo build --verbose || exit 1

# =============================================================================
# Tests (mirrors: ci.yml cargo test --verbose)
# =============================================================================
echo ""
echo "=== [4/9] Running tests ==="
cargo test --verbose -- --nocapture || exit 1

# =============================================================================
# Rust SDK Tests (mirrors: ci.yml cargo test --lib sdk)
# =============================================================================
echo ""
echo "=== [5/9] Running Rust SDK tests ==="
cargo test --lib sdk -- --nocapture || exit 1

# =============================================================================
# Cargo Deny (mirrors: ci.yml EmbarkStudios/cargo-deny-action)
# =============================================================================
echo ""
echo "=== [6/9] Running cargo deny ==="
if command -v cargo-deny >/dev/null 2>&1; then
    cargo deny --all-features check || exit 1
else
    echo "Warning: cargo-deny not installed, skipping (install with: cargo install cargo-deny)"
fi

# =============================================================================
# Python SDK Tests (mirrors: ci.yml python-sdk-check)
# =============================================================================
echo ""
echo "=== [7/9] Running Python SDK tests ==="
if command -v python3 >/dev/null 2>&1; then
    export PYTHONPATH="$REPO_ROOT/sdks/python:$PYTHONPATH"

    if [ "$(uname)" = "Darwin" ]; then
        export DYLD_LIBRARY_PATH="$REPO_ROOT/target/debug:$DYLD_LIBRARY_PATH"
    else
        export LD_LIBRARY_PATH="$REPO_ROOT/target/debug:$LD_LIBRARY_PATH"
    fi

    python3 -c "
import sys
sys.path.insert(0, '$REPO_ROOT/sdks/python')
from test_bindings import (
    test_imports, test_vec2, test_color, test_rect,
    test_transform2d, test_sprite, test_entity, test_enums
)
tests = [
    test_imports, test_vec2, test_color, test_rect,
    test_transform2d, test_sprite, test_entity, test_enums
]
passed = 0
failed = 0
for test in tests:
    try:
        if test():
            passed += 1
        else:
            failed += 1
    except Exception as e:
        print(f'  x {test.__name__} failed: {e}')
        failed += 1
print(f'Python SDK tests: {passed} passed, {failed} failed')
sys.exit(1 if failed > 0 else 0)
" || {
        echo "Error: Python SDK tests failed"
        exit 1
    }
else
    echo "Warning: Python 3 not found, skipping Python SDK tests"
fi

# =============================================================================
# Markdown Lint (mirrors: pr-validation.yml markdownlint-cli2-action)
# =============================================================================
echo ""
echo "=== [8/9] Linting markdown ==="
if command -v npx >/dev/null 2>&1; then
    npx markdownlint-cli2 "**/*.md" "!**/target/**" "!**/node_modules/**" || {
        echo "Warning: Markdown lint found issues (non-blocking)"
    }
else
    echo "Warning: npx not found, skipping markdown lint"
fi

# =============================================================================
# Large File Check (mirrors: pr-validation.yml check-file-size)
# =============================================================================
echo ""
echo "=== [9/9] Checking for large files ==="
LARGE_FILES=$(find . -type f -size +1M ! -path "./.git/*" ! -path "./target/*" ! -path "*/bin/*" ! -path "*/obj/*" ! -name "*.png" ! -name "*.jpg" ! -name "*.jpeg" ! -name "*.gif" 2>/dev/null)
if [ -n "$LARGE_FILES" ]; then
    TRACKED_LARGE=""
    echo "$LARGE_FILES" | while IFS= read -r f; do
        if ! git check-ignore -q "$f" 2>/dev/null; then
            TRACKED_LARGE="$TRACKED_LARGE$f
"
        fi
    done
    TRACKED_LARGE=$(echo "$LARGE_FILES" | while IFS= read -r f; do git check-ignore -q "$f" 2>/dev/null || echo "$f"; done)
    if [ -n "$TRACKED_LARGE" ]; then
        echo "Error: Large tracked files detected (>1MB):"
        echo "$TRACKED_LARGE"
        echo "Consider using Git LFS or adding to .gitignore."
        exit 1
    fi
fi

echo ""
echo "=============================================="
echo "  Pre-push checks completed successfully!"
echo "  Ready to push to remote."
echo "=============================================="
