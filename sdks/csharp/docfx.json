{
  "metadata": [
    {
      "src": [
        {
          "files": ["*.csproj"],
          "src": "."
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["index.md"]
      }
    ],
    "dest": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appTitle": "GoudEngine C# SDK",
      "_enableSearch": true
    }
  }
}
