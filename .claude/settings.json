{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/dangerous-cmd-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/secret-scanner.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "reviewer|spec-reviewer|code-quality-reviewer|security-auditor",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/review-verdict-validator.sh"
          }
        ]
      }
    ]
  }
}
