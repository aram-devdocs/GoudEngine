# Rust build and cargo files
/target
**/*.rs.bk
Cargo.lock

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Node.js
node_modules/
package-lock.json
!examples/typescript/feature_lab/package-lock.json

# IDE/Editor files
*.swp
*.swo
.idea
.vscode/
*.DS_Store

# Output binary
/debug
/release

# Generated SDK code (regenerated by ./codegen.sh)
**/generated/
!codegen/generated/
codegen/generated/*
!codegen/generated/goud_engine.h
!docs/src/generated/
docs/src/generated/downloads/
docs/src/generated/media/
!docs/src/generated/snippets/
!docs/src/generated/snippets/**
sdks/include/goud_engine.h
sdks/csharp/include/
sdks/python/goud_engine/include/
sdks/python/goud_engine/ffi_metadata.json
# GoudEngine/libgoud_engine.dylib

# Generated napi-rs Rust sources (regenerated by python3 codegen/gen_ts_node.py)
sdks/typescript/native/src/*.g.rs

# MacOS system files
.DS_Store

# Ignore any .NET files generated by dotnet console app in flappy_goud
**/bin/
**/obj/
**/*.csproj.user
*.sln.docstates
# *.sln

nuget_package_output

# Tiled session and project files
**.tiled-project
**.tiled-session

NuGet.local.config
libgoud_engine.dylib

# Generated diagrams intermediate files
docs/diagrams/mods.dot
docs/diagrams/module_graph.pdf

# mdBook build output
docs/book/

# Generated FFI manifest (regenerated by csbindgen)
codegen/ffi_manifest.json

# Zenflow task files
.zenflow/tasks/

# Claude session memory (local, not shared)
.claude/memory/

# Claude session state (ephemeral, per-session governance state)
.claude/state/

# Playwright MCP
.playwright-mcp/

# TypeScript compiled output
examples/typescript/**/dist/

# Screenshots from browser testing
flappy-web-*.png

# Python SDK build output
sdks/python/dist/

# Claude worktrees (ephemeral, per-session)
.claude/worktrees/
